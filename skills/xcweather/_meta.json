{
  "name": "xcweather",
  "version": "0.1.0",
  "description": "天气查询技能",
  "runtime": "python",
  "command": ["uv", "run", "scripts/main.py"],
  "env": {
    "WEATHER_API_APPID": "appid",
    "WEATHER_API_APPSECRET": "appsecret"
  },
  "parameters": {
    "city": {
      "type": "string",
      "description": "城市名称",
      "required": true
    }
  }
}